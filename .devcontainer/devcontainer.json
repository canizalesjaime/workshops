{
    //"postStartCommand":run some arbitrary commands before you start container
    "name": "Workshop",
    //"image":<add image from dockerhub> you must remove the build in the line below if you do this
    "build" : {
        "dockerfile": "./ci-cd.Dockerfile",
        "context": "../ci-cd-workshop"
    },

    "forwardPorts": [3000, 4000, 5432],
    
    "containerEnv": {
        "DISPLAY": "host.docker.internal:0.0",
        "LIBGL_ALWAYS_INDIRECT": "0"
      },
      
      "runArgs":["--net=host"],

    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder" : "/workspace"
}